# Server
NODE_ENV=development
PORT=3000

# Database (MongoDB)
DATABASE_URL="mongodb://localhost:27017/ydeck"
# For MongoDB Atlas:
# DATABASE_URL="mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/ydeck?retryWrites=true&w=majority"

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=2592000       # 30 days  (seconds)

# Device tokens
DEVICE_TOKEN_TTL=2592000      # 30 days  (seconds)
PAIRING_CODE_TTL=600          # 10 minutes (seconds)

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Agent LLM
# LLM_PROVIDER can be: openai, gemini, deepseek, openai-compatible, mock
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI-compatible providers only
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Agent loop
AGENT_LOOP_ENABLED=true
AGENT_LOOP_MAX_ROUNDS=4
AGENT_LOOP_MAX_TOOLS=8

# CORS
CORS_ORIGIN=*
